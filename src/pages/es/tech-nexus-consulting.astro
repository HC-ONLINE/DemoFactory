---
import Layout from "@/layouts/Layout.astro";
import TechNexusApp from "@/components/tech-nexus-consulting/App.astro";
import * as page from "@/content/demos/tech-nexus-consulting/es.md";

const data = page.frontmatter;
const Content = page.Content;
---

<Layout
  title={data.title}
  description={data.description}
  lang="es"
  bodyClass="min-h-full bg-slate-50 text-slate-900 antialiased"
>

  <Fragment slot="head">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" /></noscript>
  </Fragment>

  <TechNexusApp data={data}>
    <Content />
  </TechNexusApp>
</Layout>
