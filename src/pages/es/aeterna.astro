---
import Layout from "@/layouts/Layout.astro";
import AeternaApp from "@/components/aeterna/App.astro";
import * as page from "@/content/demos/aeterna/es.md";

const {
  title = "Las Épocas de la Humanidad",
  description = "Un viaje visual e inmersivo a través de las grandes épocas de la historia humana",
} = Astro.props;
const data = page.frontmatter;
const Content = page.Content;
---

<Layout title={data.title} description={data.description} lang="es">


  <AeternaApp data={data}>
    <Content />
  </AeternaApp>
</Layout>
