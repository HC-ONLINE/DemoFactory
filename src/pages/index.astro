---
import Layout from "../layouts/Layout.astro";

const withBase = (path: string) => {
  if (
    !path ||
    path.startsWith("#") ||
    path.startsWith("http://") ||
    path.startsWith("https://") ||
    path.startsWith("mailto:") ||
    path.startsWith("tel:")
  ) {
    return path;
  }

  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return `${base}${normalizedPath}`.replace(/\/+/g, "/");
};
---

<Layout
  title="DemoFactory"
  description="Punto de entrada a las demos del proyecto"
  lang="es"
>
  <main>
    <h1>DemoFactory</h1>
    <p>Selecciona una demo:</p>
    <ul>
      <li><a href={withBase("/es/elite-vows")}>Elite Vows en español</a></li>
      <li><a href={withBase("/en/elite-vows")}>Elite Vows en inglés</a></li>
    </ul>
  </main>
</Layout>
