---
import Layout from "@/layouts/Layout.astro";

const withBase = (path: string) => {
  if (
    !path ||
    path.startsWith("#") ||
    path.startsWith("http://") ||
    path.startsWith("https://") ||
    path.startsWith("mailto:") ||
    path.startsWith("tel:")
  ) {
    return path;
  }

  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return `${base}${normalizedPath}`.replace(/\/+/g, "/");
};
---

<Layout
  title="DemoFactory"
  description="Punto de entrada a las demos del proyecto"
  lang="es"
>
  <main class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="text-3xl font-semibold">DemoFactory</h1>
    <p class="mt-3 text-lg text-slate-600">Selecciona una demo:</p>
    <ul class="mt-6 space-y-3">
      <li><a class="text-blue-600 underline" href={withBase("/es/elite-vows")}>Elite Vows en español</a></li>
      <li><a class="text-blue-600 underline" href={withBase("/en/elite-vows")}>Elite Vows en inglés</a></li>
      <li><a class="text-blue-600 underline" href={withBase("/es/tech-nexus-consulting")}>TechNexus Consulting en español</a></li>
      <li><a class="text-blue-600 underline" href={withBase("/en/tech-nexus-consulting")}>TechNexus Consulting en inglés</a></li>
    </ul>
  </main>
</Layout>
