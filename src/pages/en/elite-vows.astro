---
import Layout from "@/layouts/Layout.astro";
import EliteVowsApp from "@/components/elite-vows/App.astro";
import * as page from "@/content/demos/elite-vows/en.md";

const data = page.frontmatter;
const Content = page.Content;
---

<Layout
  title={data.title}
  description={data.description}
  lang="en"
  bodyClass="min-h-full bg-[#f6f1e8] text-[#1f1a17] antialiased [font-family:'Montserrat',sans-serif]"
>

  <Fragment slot="head">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" /></noscript>
  </Fragment>

  <EliteVowsApp data={data}>
    <Content />
  </EliteVowsApp>
</Layout>
