---
import Layout from "@/layouts/Layout.astro";
import type { IndexData } from "@/types/index-page";

interface Props {
  data: IndexData;
  lang: "es" | "en";
}

const { data, lang } = Astro.props;

const withBase = (path: string) => {
  if (
    !path ||
    path.startsWith("#") ||
    path.startsWith("http://") ||
    path.startsWith("https://") ||
    path.startsWith("mailto:") ||
    path.startsWith("tel:")
  ) {
    return path;
  }

  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return `${base}${normalizedPath}`.replace(/\/+/g, "/");
};

const navigation = data.navigation ?? [];
const footerLinks = data.footer?.links ?? [];
---

<Layout
  title={data.title}
  description={data.description}
  lang={lang}
  bodyClass="min-h-full bg-white text-neutral-900 font-sans antialiased"
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div
    class="flex min-h-full flex-col"
    style="font-family: 'Inter', system-ui, sans-serif;"
  >
    <header class="border-b border-neutral-100">
      <div
        class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-5 lg:px-8"
      >
        <a href="#" class="text-lg font-bold tracking-tight text-neutral-900">
          {data.brand}
        </a>

        {
          navigation.length > 0 && (
            <nav
              class="hidden items-center gap-8 md:flex"
              aria-label="Principal"
            >
              {navigation.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "text-sm font-medium transition-colors",
                    item.active
                      ? "border-b-2 border-neutral-900 pb-0.5 text-neutral-900"
                      : "text-neutral-500 hover:text-neutral-900",
                  ]}
                >
                  {item.label}
                </a>
              ))}
            </nav>
          )
        }

        <a
          href={withBase(data.languageSwitch.url)}
          class="rounded-full bg-neutral-900 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-neutral-700"
        >
          {data.languageSwitch.label}
        </a>
      </div>
    </header>

    <main class="flex-1">
      <section class="mx-auto max-w-6xl px-6 py-16 lg:px-8 lg:py-20">
        <div class="max-w-3xl">
          <h1
            class="text-4xl font-bold tracking-tight text-neutral-900 sm:text-5xl"
          >
            {data.heading}
          </h1>
          <p class="mt-4 text-lg leading-relaxed text-neutral-500">
            {data.subheading}
          </p>
        </div>

        <div
          id="proyectos"
          class="mt-14 grid gap-10 sm:grid-cols-2 lg:gap-x-12 lg:gap-y-14"
        >
          {
            data.demos.map((demo) => (
              <article class="group flex flex-col">
                <a
                  href={withBase(demo.url)}
                  class="block overflow-hidden rounded-xl bg-neutral-100 shadow-sm ring-1 ring-neutral-200/60 transition duration-300 group-hover:shadow-md group-hover:ring-neutral-300"
                >
                  <div class="aspect-16/10 overflow-hidden">
                    <img
                      src={withBase(demo.image)}
                      alt={demo.name}
                      class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.02]"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                </a>

                <div class="mt-5 flex flex-1 flex-col">
                  <h2 class="text-xl font-bold text-neutral-900">
                    <a
                      href={withBase(demo.url)}
                      class="transition hover:text-neutral-600"
                    >
                      {demo.name}
                    </a>
                  </h2>
                  <p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-500">
                    {demo.description}
                  </p>
                  <a
                    href={withBase(demo.url)}
                    class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-neutral-900 transition hover:gap-2.5"
                  >
                    {data.viewProjectLabel}
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            ))
          }
        </div>
      </section>
    </main>

    {
      data.footer && (
        <footer class="mt-auto border-t border-neutral-100 bg-neutral-50">
          <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-8 text-sm text-neutral-500 sm:flex-row lg:px-8">
            <span class="font-semibold text-neutral-900">{data.brand}</span>

            {footerLinks.length > 0 && (
              <nav
                class="flex flex-wrap items-center justify-center gap-6"
                aria-label="Enlaces"
              >
                {footerLinks.map((link) => (
                  <a
                    href={
                      link.href.startsWith("#")
                        ? link.href
                        : withBase(link.href)
                    }
                    class="transition hover:text-neutral-900"
                  >
                    {link.label}
                  </a>
                ))}
              </nav>
            )}

            <p class="text-center sm:text-right">{data.footer.copyright}</p>
          </div>
        </footer>
      )
    }
  </div>
</Layout>
