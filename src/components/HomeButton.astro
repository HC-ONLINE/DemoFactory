---
const base = import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL;
const homeUrl = `${base}/`;
const currentPath = Astro.url.pathname;
const isHome =
  currentPath === homeUrl || currentPath === base || currentPath === "/";
---

{
  !isHome && (
    <a
      href={homeUrl}
      class="fixed bottom-8 right-8 z-9999 flex items-center justify-center w-14 h-14 bg-indigo-600/90 backdrop-blur-md text-white rounded-full shadow-[0_4px_20px_rgba(79,70,229,0.5)] border border-indigo-400/30 hover:bg-indigo-500 hover:scale-110 hover:shadow-[0_4px_25px_rgba(79,70,229,0.7)] transition-all duration-300 group overflow-hidden"
      aria-label="Volver al inicio"
      title="Volver al inicio"
    >
      <span class="absolute inset-0 rounded-full bg-white opacity-0 group-hover:opacity-20 transition-opacity duration-300" />
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6 transform group-hover:scale-110 transition-transform duration-300"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
        />
      </svg>
    </a>
  )
}
