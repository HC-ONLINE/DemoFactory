---
import { Picture } from 'astro:assets';
import { getImage } from '@/utils/image-registry';

interface DemoLink {
  label: string;
  href: string;
}

interface DemoData {
  title: string;
  description: string;
  navigation: DemoLink[];
  hero: {
    eyebrow: string;
    title: string;
    description: string;
    primaryCta: DemoLink;
    secondaryCta: DemoLink;
    image: string;
    highlights: string[];
  };
  about: {
    eyebrow: string;
    title: string;
    cards: Array<{
      title: string;
      description: string;
    }>;
  };
  services: {
    eyebrow: string;
    title: string;
    description: string;
    cards: Array<{
      title: string;
      description: string;
      icon: string;
      featured?: boolean;
      bullets: string[];
    }>;
  };
  metrics: {
    eyebrow: string;
    title: string;
    description: string;
    cards: Array<{
      value: string;
      label: string;
    }>;
  };
  process: {
    eyebrow: string;
    title: string;
    steps: Array<{
      title: string;
      description: string;
    }>;
  };
  testimonials: {
    eyebrow: string;
    title: string;
    items: Array<{
      quote: string;
      author: string;
      role: string;
    }>;
  };
  faq: {
    eyebrow: string;
    title: string;
    items: Array<{
      question: string;
      answer: string;
    }>;
  };
  cta: {
    eyebrow: string;
    title: string;
    description: string;
    primaryCta: DemoLink;
  };
  footer: {
    brand: string;
    copyright: string;
    links: DemoLink[];
  };
}

const { data } = Astro.props as { data: DemoData };

const withBase = (path: string) => {
  if (
    !path ||
    path.startsWith("#") ||
    path.startsWith("http://") ||
    path.startsWith("https://") ||
    path.startsWith("mailto:") ||
    path.startsWith("tel:")
  ) {
    return path;
  }

  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return `${base}${normalizedPath}`.replace(/\/+/, "/");
};

const heroImage = getImage(data.hero.image);
---

<div class="min-h-screen bg-slate-50 text-slate-900" id="tech-nexus-root">
  <header
    class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/80 backdrop-blur-xl"
  >
    <div
      class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6 lg:px-10"
    >
      <a
        class="flex items-center gap-3 text-lg font-semibold tracking-[0.2em] text-slate-900 uppercase"
        href="#tech-nexus-root"
      >
        <span class="material-symbols-outlined text-2xl text-blue-600"
          >hexagon</span
        >
        {data.footer.brand}
      </a>
      <nav class="hidden items-center gap-7 md:flex">
        {
          data.navigation.map((item) => (
            <a
              class="text-sm font-medium text-slate-600 transition-colors hover:text-blue-600"
              href={item.href}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <a
        class="hidden rounded-full bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-700 md:inline-flex"
        href="#contact"
      >
        {data.hero.primaryCta.label}
      </a>
      <button
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 text-slate-700 md:hidden"
        id="mobile-menu-btn"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="material-symbols-outlined text-[22px]">menu</span>
      </button>
    </div>
    <div
      class="hidden border-t border-slate-200 bg-white md:hidden"
      id="mobile-menu"
    >
      <div class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-6">
        {
          [
            ...data.navigation,
            { label: data.hero.primaryCta.label, href: "#contact" },
          ].map((item) => (
            <a
              class="text-sm font-medium text-slate-600 transition-colors hover:text-blue-600"
              href={item.href}
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </header>

  <main>
    <section
      class="relative overflow-hidden bg-[radial-gradient(circle_at_top_left,rgba(37,99,235,0.16),transparent_33%),linear-gradient(135deg,#f8fbff_0%,#f8fafc_100%)] py-24 md:py-32"
    >
      <div
        class="absolute inset-x-0 top-0 h-64 bg-linear-to-b from-blue-100/35 to-transparent"
      >
      </div>
      <div
        class="mx-auto grid max-w-7xl grid-cols-1 gap-14 px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:px-10"
      >
        <div class="animate-fade-in-up">
          <p
            class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-600"
          >
            {data.hero.eyebrow}
          </p>
          <h1
            class="mt-6 max-w-3xl text-4xl font-semibold leading-tight text-slate-950 sm:text-5xl lg:text-6xl"
          >
            {data.hero.title}
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
            {data.hero.description}
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              class="inline-flex items-center justify-center rounded-full bg-blue-600 px-7 py-3.5 text-sm font-semibold text-white transition-transform hover:-translate-y-0.5 hover:bg-blue-700"
              href={data.hero.primaryCta.href}
            >
              {data.hero.primaryCta.label}
              <span class="material-symbols-outlined ml-2">arrow_forward</span>
            </a>
            <a
              class="inline-flex items-center justify-center rounded-full border border-slate-300 px-7 py-3.5 text-sm font-semibold text-slate-700 transition-colors hover:border-blue-400 hover:text-blue-600"
              href={data.hero.secondaryCta.href}
            >
              {data.hero.secondaryCta.label}
            </a>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            {
              data.hero.highlights.map((item) => (
                <span class="rounded-full border border-slate-200 bg-white/80 px-4 py-2 text-sm text-slate-600 shadow-sm">
                  {item}
                </span>
              ))
            }
          </div>
        </div>
        <div class="animate-fade-in-up">
          <div
            class="rounded-4xl border border-slate-200 bg-white p-4 shadow-[0_30px_80px_rgba(15,23,42,0.12)]"
          >
            {heroImage && (
              <Picture
                src={heroImage}
                alt={data.hero.title}
                loading="eager"
                decoding="async"
                formats={['webp']}
                class="h-105 w-full rounded-[1.4rem] object-cover"
              />
            )}
            <div
              class="mt-4 rounded-[1.2rem] border border-blue-100 bg-blue-50/70 p-5"
            >
              <p
                class="text-sm font-semibold uppercase tracking-[0.25em] text-blue-700"
              >
                {data.about.eyebrow}
              </p>
              <p class="mt-2 text-sm leading-7 text-slate-700">
                {data.about.cards[0]?.description}
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section
      class="mx-auto grid max-w-7xl grid-cols-1 gap-10 px-6 py-20 lg:grid-cols-[0.9fr_1.1fr] lg:px-10"
      id="about"
    >
      <div class="animate-fade-in-up">
        <p
          class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-600"
        >
          {data.about.eyebrow}
        </p>
        <h2 class="mt-4 text-3xl font-semibold text-slate-950 sm:text-4xl">
          {data.about.title}
        </h2>
        <div
          class="prose prose-slate mt-8 max-w-none text-lg leading-8 text-slate-600"
        >
          <slot />
        </div>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {
          data.about.cards.map((card) => (
            <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
              <h3 class="text-lg font-semibold text-slate-950">{card.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">
                {card.description}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="bg-slate-950 py-20 text-white" id="services">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <div class="max-w-3xl animate-fade-in-up">
          <p
            class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-300"
          >
            {data.services.eyebrow}
          </p>
          <h2 class="mt-4 text-3xl font-semibold sm:text-4xl">
            {data.services.title}
          </h2>
          <p class="mt-5 text-lg leading-8 text-slate-300">
            {data.services.description}
          </p>
        </div>
        <div class="mt-12 grid gap-6 lg:grid-cols-3">
          {
            data.services.cards.map((card) => (
              <article
                class={`rounded-[1.7rem] border p-8 shadow-lg ${card.featured ? "border-blue-400 bg-slate-900" : "border-slate-800 bg-slate-900/80"}`}
              >
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-500/15 text-blue-300">
                  <span class="material-symbols-outlined text-[28px]">
                    {card.icon}
                  </span>
                </div>
                <h3 class="mt-6 text-xl font-semibold text-white">
                  {card.title}
                </h3>
                <p class="mt-4 text-sm leading-7 text-slate-300">
                  {card.description}
                </p>
                <ul class="mt-6 space-y-3 text-sm text-slate-300">
                  {card.bullets.map((bullet) => (
                    <li class="flex items-start gap-2">
                      <span class="material-symbols-outlined mt-0.5 text-blue-400">
                        check_circle
                      </span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-20 lg:px-10" id="insights">
      <div class="animate-fade-in-up">
        <p
          class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-600"
        >
          {data.metrics.eyebrow}
        </p>
        <h2 class="mt-4 text-3xl font-semibold text-slate-950 sm:text-4xl">
          {data.metrics.title}
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
          {data.metrics.description}
        </p>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          data.metrics.cards.map((card) => (
            <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
              <p class="text-4xl font-semibold text-slate-950">{card.value}</p>
              <p class="mt-3 text-sm leading-7 text-slate-600">{card.label}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="bg-slate-100 py-20" id="process">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <div class="animate-fade-in-up">
          <p
            class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-600"
          >
            {data.process.eyebrow}
          </p>
          <h2 class="mt-4 text-3xl font-semibold text-slate-950 sm:text-4xl">
            {data.process.title}
          </h2>
        </div>
        <div class="mt-12 grid gap-6 lg:grid-cols-3">
          {
            data.process.steps.map((step, index) => (
              <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-sm font-semibold text-white">
                  0{index + 1}
                </div>
                <h3 class="mt-6 text-xl font-semibold text-slate-950">
                  {step.title}
                </h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">
                  {step.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-20 lg:px-10" id="testimonials">
      <div class="animate-fade-in-up">
        <p
          class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-600"
        >
          {data.testimonials.eyebrow}
        </p>
        <h2 class="mt-4 text-3xl font-semibold text-slate-950 sm:text-4xl">
          {data.testimonials.title}
        </h2>
      </div>
      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        {
          data.testimonials.items.map((item) => (
            <blockquote class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
              <p class="text-lg leading-8 text-slate-700">“{item.quote}”</p>
              <footer class="mt-6">
                <p class="font-semibold text-slate-950">{item.author}</p>
                <p class="mt-1 text-sm text-slate-500">{item.role}</p>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 pb-20 lg:px-10" id="faq">
      <div
        class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm lg:p-10"
      >
        <div class="animate-fade-in-up">
          <p
            class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-600"
          >
            {data.faq.eyebrow}
          </p>
          <h2 class="mt-4 text-3xl font-semibold text-slate-950 sm:text-4xl">
            {data.faq.title}
          </h2>
        </div>
        <div class="mt-10 space-y-4">
          {
            data.faq.items.map((item) => (
              <details class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                <summary class="cursor-pointer text-base font-semibold text-slate-900">
                  {item.question}
                </summary>
                <p class="mt-3 text-sm leading-7 text-slate-600">
                  {item.answer}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 pb-24 lg:px-10" id="contact">
      <div
        class="grid gap-10 rounded-4xl border border-slate-200 bg-slate-950 p-8 text-white shadow-[0_30px_80px_rgba(15,23,42,0.18)] lg:grid-cols-[0.95fr_1.05fr] lg:p-10"
      >
        <div class="animate-fade-in-up">
          <p
            class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-300"
          >
            {data.cta.eyebrow}
          </p>
          <h2 class="mt-4 text-3xl font-semibold sm:text-4xl">
            {data.cta.title}
          </h2>
          <p class="mt-5 text-lg leading-8 text-slate-300">
            {data.cta.description}
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <span
              class="rounded-full border border-slate-800 bg-slate-900/80 px-4 py-2 text-sm text-slate-300"
              >30 minute consultation</span
            >
            <span
              class="rounded-full border border-slate-800 bg-slate-900/80 px-4 py-2 text-sm text-slate-300"
              >Actionable roadmap</span
            >
          </div>
        </div>
        <form
          class="rounded-3xl bg-white p-6 text-slate-900 shadow-inner"
          id="lead-form"
        >
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block text-sm font-medium text-slate-700">
              <span class="mb-2 block">Name</span>
              <input
                class="w-full rounded-2xl border border-slate-200 px-4 py-3 focus:border-blue-500 focus:outline-none"
                placeholder="Juan"
                required
                type="text"
              />
            </label>
            <label class="block text-sm font-medium text-slate-700">
              <span class="mb-2 block">Company</span>
              <input
                class="w-full rounded-2xl border border-slate-200 px-4 py-3 focus:border-blue-500 focus:outline-none"
                placeholder="Acme"
                required
                type="text"
              />
            </label>
          </div>
          <label class="mt-4 block text-sm font-medium text-slate-700">
            <span class="mb-2 block">Email</span>
            <input
              class="w-full rounded-2xl border border-slate-200 px-4 py-3 focus:border-blue-500 focus:outline-none"
              placeholder="name@company.com"
              required
              type="email"
            />
          </label>
          <label class="mt-4 block text-sm font-medium text-slate-700">
            <span class="mb-2 block">What are you trying to improve?</span>
            <textarea
              class="min-h-28 w-full rounded-2xl border border-slate-200 px-4 py-3 focus:border-blue-500 focus:outline-none"
              placeholder="We want more qualified pipeline and a cleaner attribution system."
            ></textarea>
          </label>
          <button
            class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-blue-600 px-6 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-blue-700"
            type="submit"
          >
            {data.cta.primaryCta.label}
          </button>
          <p class="mt-3 text-center text-sm text-slate-500">
            We only use your details to reply with a tailored recommendation.
          </p>
          <div
            class="mt-4 hidden rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-700"
            id="form-success"
          >
            Thanks! We will reach out within one business day.
          </div>
        </form>
      </div>
    </section>
  </main>

  <footer class="border-t border-slate-200 bg-white py-12">
    <div
      class="mx-auto flex max-w-7xl flex-col gap-6 px-6 text-sm text-slate-600 md:flex-row md:items-center md:justify-between lg:px-10"
    >
      <p>{data.footer.copyright}</p>
      <div class="flex flex-wrap gap-4">
        {
          data.footer.links.map((link) => (
            <a class="transition-colors hover:text-blue-600" href={link.href}>
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </footer>
</div>

<style>
  /* Smooth scroll behavior and reveal animation base styles */
  html {
    scroll-behavior: smooth;
  }

  .reveal,
  .animate-fade-in-up,
  .reveal-left,
  .reveal-right,
  .reveal-scale {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 700ms cubic-bezier(0.2, 0.9, 0.2, 1),
      transform 700ms cubic-bezier(0.2, 0.9, 0.2, 1);
    will-change: transform, opacity;
  }

  .reveal-left {
    transform: translateX(-28px);
  }
  .reveal-right {
    transform: translateX(28px);
  }
  .reveal-scale {
    transform: scale(0.98) translateY(8px);
  }

  .reveal-visible {
    opacity: 1;
    transform: none;
  }

  /* Small utility to visually highlight targets after scroll */
  .ring-2 {
    box-shadow: 0 0 0 4px rgba(147, 197, 253, 0.35);
  }
</style>

<script>
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  mobileMenuBtn?.addEventListener("click", () => {
    const isOpen = mobileMenuBtn.getAttribute("aria-expanded") === "true";
    mobileMenuBtn.setAttribute("aria-expanded", String(!isOpen));
    mobileMenu?.classList.toggle("hidden");
  });

  document.getElementById("lead-form")?.addEventListener("submit", (event) => {
    event.preventDefault();
    const success = document.getElementById("form-success");
    success?.classList.remove("hidden");
  });
</script>

<script>
  // Smooth-scroll for anchor links and highlight target on arrival
  document.querySelectorAll('a[href^="#"]').forEach((a) => {
    a.addEventListener("click", (ev) => {
      const href = a.getAttribute("href");
      if (!href || href === "#") return;
      const target = document.querySelector(href);
      if (target) {
        ev.preventDefault();
        target.scrollIntoView({ behavior: "smooth", block: "start" });
        // briefly highlight
        target.classList.add("ring-2", "ring-blue-300");
        setTimeout(
          () => target.classList.remove("ring-2", "ring-blue-300"),
          1200,
        );
      }
    });
  });

  // IntersectionObserver for reveal animations
  const revealSelector =
    ".reveal, .animate-fade-in-up, .reveal-left, .reveal-right, .reveal-scale";
  const reveals = Array.from(document.querySelectorAll(revealSelector));
  if (reveals.length) {
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("reveal-visible");
          }
        });
      },
      { threshold: 0.12 },
    );

    reveals.forEach((el) => {
      obs.observe(el);
    });
  }
</script>
