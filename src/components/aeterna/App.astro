---
import "@/components/aeterna/style.css";

interface DemoLink {
  label: string;
  href: string;
}

interface DemoEvent {
  time: string;
  title: string;
  venue: string;
  icon: string;
  imageLabel: string;
  image: string;
}

interface DetailItem {
  /** Icono, símbolo, letra o número identificador (ej: '𓂀', 'SPQR', '[AI]') */
  iconOrLabel: string;
  /** Breve descripción del hito o elemento histórico */
  description: string;
}

interface EpochSection {
  /** Rango temporal de la época (ej: '3000 a.C. – 30 a.C.') */
  eraTag: string;
  /** Título principal de la sección (soporta saltos de línea con <br /> si es necesario) */
  title: string;
  /** Descripción o resumen histórico de la era */
  description: string;
  /** Nombre de la imagen de fondo alojada en public (ej: '/aeterna/romana.png') */
  image: string;
  /** Listado de 3 hitos o detalles clave de la civilización */
  details: DetailItem[];
  /** Elemento o etiqueta decorativa del lado derecho (ej: 'ANKH', 'SYS') */
  decoLabel?: string;
}

interface DemoData {
  /** Configuración de la pantalla de bienvenida/introducción */
  intro: {
    title: string;
    subtitle: string;
    startYear: string;
    endYear: string;
  };
  /** Secciones cronológicas mapeadas dinámicamente */
  epochs: {
    prehistory: EpochSection;
    egypt: EpochSection;
    greece: EpochSection;
    rome: EpochSection;
    medieval: EpochSection;
    renaissance: EpochSection;
    discovery: EpochSection;
    enlightenment: EpochSection;
    industrial: EpochSection;
    modern: EpochSection;
    cyberpunk: EpochSection;
  };
}

const { data } = Astro.props as { data: DemoData };

const withBase = (path: string) => {
  if (
    !path ||
    path.startsWith("#") ||
    path.startsWith("http://") ||
    path.startsWith("https://") ||
    path.startsWith("mailto:") ||
    path.startsWith("tel:")
  ) {
    return path;
  }

  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return `${base}${normalizedPath}`.replace(/\/+/g, "/");
};
---

<div class="site-header" id="site-header" aria-label="Encabezado del sitio">
  <h1>Aeterna</h1>
</div>
<!-- Nav indicator -->
<nav id="epoch-nav" aria-label="Navegación por épocas">
  <div class="nav-dots">
    <button class="nav-dot active" data-epoch="0" aria-label="Introducción"
    ></button>
    <button class="nav-dot" data-epoch="1" aria-label="Prehistoria"></button>
    <button class="nav-dot" data-epoch="2" aria-label="Egipcia"></button>
    <button class="nav-dot" data-epoch="3" aria-label="Grecia"></button>
    <button class="nav-dot" data-epoch="4" aria-label="Romana"></button>
    <button class="nav-dot" data-epoch="5" aria-label="Medieval"></button>
    <button class="nav-dot" data-epoch="6" aria-label="Renacimiento"></button>
    <button class="nav-dot" data-epoch="7" aria-label="Descubrimientos"
    ></button>
    <button class="nav-dot" data-epoch="8" aria-label="Ilustración"></button>
    <button class="nav-dot" data-epoch="9" aria-label="Industrial"></button>
    <button class="nav-dot" data-epoch="10" aria-label="Moderna"></button>
    <button class="nav-dot" data-epoch="11" aria-label="Cyberpunk"></button>
  </div>
  <span id="epoch-label" class="nav-label" aria-live="polite">Inicio</span>
</nav>

<!-- Scroll hint -->
<div id="scroll-hint" class="scroll-hint" aria-hidden="true">
  <span class="scroll-text">SCROLL</span>
  <div class="scroll-arrow"></div>
</div>

<!-- ═══════════ INTRO ═══════════ -->
<section class="epoch epoch-intro" data-epoch="0" id="intro">
  <div class="epoch-bg intro-bg"></div>
  <div class="intro-content">
    <h1 class="intro-title" set:html={data.intro.title} />
    <p class="intro-subtitle">
      {data.intro.subtitle}
    </p>
    <div class="intro-divider"></div>
    <div class="intro-years">
      <span>{data.intro.startYear}</span>
      <div class="years-line"></div>
      <span>{data.intro.endYear}</span>
    </div>
  </div>
  <div class="intro-particles" aria-hidden="true">
    {
      Array.from({ length: 30 }).map((_, i) => (
        <div
          class="particle"
          style={`--delay: ${Math.random() * 5}s; --x: ${Math.random() * 100}%; --dur: ${3 + Math.random() * 4}s;`}
        />
      ))
    }
  </div>
</section>

