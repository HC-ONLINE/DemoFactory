<!-- ═══════════ SCROLL SCRIPT ═══════════ -->
<script>
  const epochs = document.querySelectorAll(".epoch");
  const navDots = document.querySelectorAll(".nav-dot");
  const epochLabel = document.getElementById("epoch-label");
  const siteHeader = document.getElementById("site-header");
  const scrollHint = document.getElementById("scroll-hint");

  const epochNames = [
    "Inicio",
    "Prehistoria",
    "Egipcia",
    "Grecia",
    "Romana",
    "Medieval",
    "Renacimiento",
    "Descubrimiento",
    "Ilustración",
    "Industrial",
    "Moderna",
    "Cyberpunk",
  ];
  const epochClasses = [
    "intro",
    "prehistory",
    "egypt",
    "greece",
    "rome",
    "medieval",
    "renaissance",
    "discovery",
    "enlightenment",
    "industrial",
    "modern",
    "cyber",
  ];

  const updateHeaderStyle = (index: number) => {
    if (!siteHeader) return;
    const epochClass = epochClasses[index] ?? "intro";
    siteHeader.className = `site-header site-header-${epochClass}`;
  };

  updateHeaderStyle(0);

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const target = entry.target as HTMLElement;
        if (entry.isIntersecting) {
          target.classList.add("in-view");
          const idx = Number(target.dataset.epoch) || 0;
          navDots.forEach((d, i) => d.classList.toggle("active", i === idx));
          if (epochLabel) epochLabel.textContent = epochNames[idx] ?? "";
          updateHeaderStyle(idx);
        } else {
          target.classList.remove("in-view");
        }
      });
    },
    { threshold: 0.4 },
  );

  epochs.forEach((s) => observer.observe(s));

  // Hide scroll hint after first scroll
  let hinted = false;
  window.addEventListener(
    "scroll",
    () => {
      if (!hinted && window.scrollY > 100) {
        hinted = true;
        scrollHint?.classList.add("hidden");
      }
    },
    { passive: true },
  );

  // Nav dot click → scroll to section
  navDots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      const target = document.querySelector(`[data-epoch="${i}"]`);
      target?.scrollIntoView({ behavior: "smooth" });
    });
  });
</script>
